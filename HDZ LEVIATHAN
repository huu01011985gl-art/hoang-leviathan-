local function controlBoat(dest, speed)
    local seat
    for _, c in pairs(character:GetChildren()) do
        if c:IsA("VehicleSeat") and c.Occupant == character.Humanoid then seat = c; break end
    end
    if not seat then seat = getInBoat(); if not seat then return false end end
    local boat = seat.Parent
    local boatHrp = boat:FindFirstChild("HumanoidRootPart")
    if not boatHrp then return false end
    local throttle = seat:FindFirstChild("Throttle") or Instance.new("NumberValue")
    throttle.Name = "Throttle"; throttle.Value = speed; throttle.Parent = seat
    local steer = seat:FindFirstChild("Steer") or Instance.new("NumberValue")
    steer.Name = "Steer"; steer.Value = 0; steer.Parent = seat
    boatHrp.CFrame = CFrame.lookAt(boatHrp.Position, dest)
    return true
end

local function startAvoid()
    if avoidThread then return end
    avoidThread = task.spawn(function()
        while avoidActive do
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("Part") and v.Name and v.Name:lower():find("lightning") then
                            if (v.Position - hrp.Position).Magnitude < 50 then
                                hrp.CFrame = hrp.CFrame + Vector3.new(0,120,0)
                                Notify("⚠️ Né","Đã bay lên tránh sét",1)
                                break
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
end

local function stopAvoid()
    if avoidThread then task.cancel(avoidThread); avoidThread = nil end
end

local function shootAt(pos)
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.lookAt(hrp.Position, pos) end
    pcall(function()
        local vu = game:GetService("VirtualUser")
        vu:Button1Down(Vector2.new(0,0)); task.wait(0.05); vu:Button1Up(Vector2.new(0,0))
    end)
end

local function adjustAim(heartPos)
    local seat
    for _, c in pairs(character:GetChildren()) do
        if c:IsA("VehicleSeat") and c.Occupant == character.Humanoid then seat = c; break end
    end
    if not seat then return end
    local boat = seat.Parent
    local boatHrp = boat:FindFirstChild("HumanoidRootPart")
    if not boatHrp then return end
    local targetDir = (heartPos - boatHrp.Position).Unit
    local currentDir = boatHrp.CFrame.LookVector
    local angle = math.acos(currentDir:Dot(targetDir))
    local steer = seat:FindFirstChild("Steer")
    if steer then steer.Value = math.clamp(angle * 2, -1, 1) end
    task.wait(0.3)
    if steer then steer.Value = 0 end
end

local function teleportToLevi()
    updateLevi()
    if leviInfo.active and leviInfo.pos then
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(leviInfo.pos) * CFrame.new(0,35,-20)
            Notify("✅ Teleport","Đã đến Leviathan",1)
        end
    else
        Notify("Không thấy","Leviathan chưa xuất hiện",2)
    end
end
