local function checkChip()
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, it in pairs(bp:GetChildren()) do
            if it.Name and (it.Name:lower():find("chip") or it.Name:lower():find("leviathan")) then
                leviInfo.hasChip = true; return true
            end
        end
    end
    if character then
        for _, it in pairs(character:GetChildren()) do
            if it.Name and (it.Name:lower():find("chip") or it.Name:lower():find("leviathan")) then
                leviInfo.hasChip = true; return true
            end
        end
    end
    leviInfo.hasChip = false; return false
end

local function buyChip()
    if checkChip() then Notify("Chip","✅ Đã có chip",2) return end
    local npc
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name and v.Name:lower():find("explorer") then npc = v; break end
    end
    if not npc then Notify("Lỗi","Không tìm thấy Explorer ở Tiki!",3) return end
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local npcPos = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if npcPos then hrp.CFrame = npcPos.CFrame * CFrame.new(0,0,5); task.wait(1) end
    end
    for _, v in pairs(player.PlayerGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible and v.Text:lower():find("chip") then
            pcall(v.Click); break
        end
    end
    task.wait(1)
    if checkChip() then Notify("Chip","🛒 Mua thành công",2)
    else Notify("Chip","Thất bại, cần 1000$",3) end
end

local function buyBoat(boatName)
    if player.Backpack:FindFirstChild(boatName) then
        Notify("Thuyền","✅ Đã có "..boatName,2) return
    end
    local npc
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name and v.Name:lower():find("boat dealer") then npc = v; break end
    end
    if not npc then Notify("Lỗi","Không tìm thấy Boat Dealer ở Tiki!",3) return end
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local npcPos = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if npcPos then hrp.CFrame = npcPos.CFrame * CFrame.new(0,0,5); task.wait(1) end
    end
    for _, v in pairs(player.PlayerGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible and v.Text:lower():find(boatName:lower()) then
            pcall(v.Click); break
        end
    end
    Notify("Mua thuyền","Đã mua "..boatName,2)
end

local function spawnBoat()
    if not settings.boatName then return false end
    local bp = player:FindFirstChild("Backpack")
    local boat = bp and bp:FindFirstChild(settings.boatName) or (character and character:FindFirstChild(settings.boatName))
    if not boat then Notify("Lỗi","Chưa có thuyền "..settings.boatName,2) return false end
    local newBoat = boat:Clone()
    newBoat.Parent = character
    task.wait(0.5)
    pcall(function() newBoat:Activate() end)
    return true
end

local function getInBoat()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") and obj.Parent and obj.Parent.Name == settings.boatName then
            local hrp = obj.Parent:FindFirstChild("HumanoidRootPart")
            if hrp and character and (hrp.Position - character.HumanoidRootPart.Position).Magnitude < 20 then
                pcall(function() obj:Sit(character.Humanoid) end)
                task.wait(0.5)
                return obj
            end
        end
    end
    return nil
end
