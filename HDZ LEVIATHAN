local function startAvoidance()
    if avoidThread then return end
    avoidThread = task.spawn(function()
        while avoidanceActive do
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("Part") and v.Name and v.Name:lower():find("lightning") then
                            if (v.Position - hrp.Position).Magnitude < 50 then
                                hrp.CFrame = hrp.CFrame + Vector3.new(0,100,0)
                                Notify("⚠️ Né","Đã bay lên tránh sét",1)
                                break
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
end

local function stopAvoidance()
    if avoidThread then task.cancel(avoidThread); avoidThread = nil end
end

local function spawnBoat(boatName)
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return false end
    local bp = player:FindFirstChild("Backpack")
    local boat = bp and bp:FindFirstChild(boatName) or char:FindFirstChild(boatName)
    if not boat then Notify("Lỗi","Chưa có thuyền "..boatName,2) return false end
    local newBoat = boat:Clone()
    newBoat.Parent = char
    task.wait(0.5)
    pcall(function() newBoat:Activate() end)
    return true
end

local function getInBoat()
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return nil end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") and obj.Parent and obj.Parent.Name == settings.boatName then
            local hrp = obj.Parent:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - char.HumanoidRootPart.Position).Magnitude < 20 then
                pcall(function() obj:Sit(char.Humanoid) end)
                task.wait(0.5)
                return obj
            end
        end
    end
    return nil
end

local function controlBoat(destination, speed)
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return false end
    local seat
    for _, c in pairs(char:GetChildren()) do
        if c:IsA("VehicleSeat") and c.Occupant == char.Humanoid then seat = c; break end
    end
    if not seat then seat = getInBoat(); if not seat then return false end end
    local boat = seat.Parent
    local boatHrp = boat:FindFirstChild("HumanoidRootPart")
    if not boatHrp then return false end
    local throttle = seat:FindFirstChild("Throttle") or Instance.new("NumberValue")
    throttle.Name = "Throttle"; throttle.Value = speed; throttle.Parent = seat
    local steer = seat:FindFirstChild("Steer") or Instance.new("NumberValue")
    steer.Name = "Steer"; steer.Value = 0; steer.Parent = seat
    boatHrp.CFrame = CFrame.lookAt(boatHrp.Position, destination)
    return true
end

local function shootAtHeart(pos)
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.lookAt(hrp.Position, pos) end
    pcall(function()
        local vu = game:GetService("VirtualUser")
        vu:Button1Down(Vector2.new(0,0)); task.wait(0.05); vu:Button1Up(Vector2.new(0,0))
    end)
end

local function adjustBoatAim(heartPos)
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return end
    local seat
    for _, c in pairs(char:GetChildren()) do
        if c:IsA("VehicleSeat") and c.Occupant == char.Humanoid then seat = c; break end
    end
    if not seat then return end
    local boat = seat.Parent
    local boatHrp = boat:FindFirstChild("HumanoidRootPart")
    if not boatHrp then return end
    local targetDir = (heartPos - boatHrp.Position).Unit
    local currentDir = boatHrp.CFrame.LookVector
    local angle = math.acos(currentDir:Dot(targetDir))
    local steer = seat:FindFirstChild("Steer")
    if steer then steer.Value = math.clamp(angle * 2, -1, 1) end
    task.wait(0.3)
    if steer then steer.Value = 0 end
end
