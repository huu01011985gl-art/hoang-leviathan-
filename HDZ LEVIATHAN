local function Notify(title, text, dur)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title, Text = text, Duration = dur or 3
    })
end

local function fetchStats()
    local data = player:FindFirstChild("Data") or player:FindFirstChild("PlayerStats")
    local lv = data and data:FindFirstChild("Level") and data.Level.Value or 0
    local exp = data and data:FindFirstChild("Experience") and data.Experience.Value or 0
    local req = data and data:FindFirstChild("RequiredExperience") and data.RequiredExperience.Value or 1000
    local money = data and data:FindFirstChild("Money") and data.Money.Value or 0
    local hum = character and character:FindFirstChild("Humanoid")
    local hp = hum and math.floor(hum.Health) or 0
    local maxHp = hum and math.floor(hum.MaxHealth) or 100
    local eng = character and character:FindFirstChild("Energy") and character.Energy.Value or 0
    local maxEng = character and character:FindFirstChild("Energy") and (character.Energy.MaxValue or 100) or 100
    return lv, exp, req, money, hp, maxHp, eng, maxEng
end

local function updateLevi()
    leviInfo.active = false
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and obj.Name:lower():find("leviathan") then
            leviInfo.active = true
            leviInfo.lastSeen = tick()
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hrp then leviInfo.pos = hrp.Position end
            local hum = obj:FindFirstChild("Humanoid")
            if hum then leviInfo.health = math.floor(hum.Health) end
            return
        end
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and (obj.Name:lower():find("heart") or obj.Name:lower():find("leviathanheart")) then
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            leviInfo.heartPos = hrp and hrp.Position or obj.Position
            return
        end
    end
    if tick() - (leviInfo.lastSeen or 0) > 60 then
        leviInfo.active = false
        leviInfo.health = 0
    end
end
