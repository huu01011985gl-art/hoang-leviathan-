local function mission_FindAndShoot()
    if currentMission ~= "NONE" then Notify("Đang bận","Dừng nhiệm vụ trước",2) return end
    currentMission = "FIND"
    avoidanceActive = true
    startAvoidance()
    task.spawn(function()
        local player = game.Players.LocalPlayer
        if not spawnBoat(settings.boatName) then currentMission="NONE"; avoidanceActive=false; return end
        task.wait(1)
        if not getInBoat() then Notify("Lỗi","Không lên được thuyền",2); currentMission="NONE"; avoidanceActive=false; return end
        while currentMission == "FIND" do
            updateLeviathanInfo()
            if leviathanInfo.isActive and leviathanInfo.position then
                Notify("✅ Tìm thấy","Leviathan đã xuất hiện!",2)
                break
            end
            controlBoat(CFrame.new(5000,0,-2000).Position, settings.fastSpeed)
            task.wait(2)
        end
        while currentMission == "FIND" and leviathanInfo.position do
            local dist = (leviathanInfo.position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist < 60 then break end
            controlBoat(leviathanInfo.position, settings.fastSpeed)
            task.wait(1)
        end
        local attempts = 0
        while currentMission == "FIND" and attempts < settings.maxShootAttempts do
            updateLeviathanInfo()
            if not leviathanInfo.isActive then
                Notify("Leviathan chết","Chờ tim rơi...",2)
                task.wait(3)
                updateLeviathanInfo()
                if leviathanInfo.heartDropped then
                    Notify("❤️ Tim rơi","Chuyển sang kéo tim",2)
                    currentMission = "PULL"
                    break
                else
                    Notify("Chưa thấy tim","Thử lại...",2)
                end
                attempts = attempts + 1
                continue
            end
            shootAtHeart(leviathanInfo.position)
            attempts = attempts + 1
            Notify("Bắn tim","Lần "..attempts.."/"..settings.maxShootAttempts,1)
            local oldHealth = leviathanInfo.health
            task.wait(1)
            updateLeviathanInfo()
            if leviathanInfo.health < oldHealth - 300 then
                Notify("❤️ Trúng tim!","Leviathan bị thương nặng",2)
                task.wait(3)
                updateLeviathanInfo()
                if not leviathanInfo.isActive then
                    Notify("🎉 Tiêu diệt","Kết thúc nhiệm vụ",3)
                    currentMission = "NONE"
                    break
                end
            else
                adjustBoatAim(leviathanInfo.position)
                task.wait(0.5)
            end
        end
        if attempts >= settings.maxShootAttempts and currentMission=="FIND" then
            Notify("Thất bại","Không bắn trúng tim",3)
            currentMission = "NONE"
        end
        avoidanceActive = false
        stopAvoidance()
    end)
end

local function mission_PullHeart(dest)
    if currentMission ~= "NONE" then Notify("Đang bận","Dừng nhiệm vụ trước",2) return end
    currentMission = "PULL"
    settings.pullDestination = dest
    avoidanceActive = true
    startAvoidance()
    task.spawn(function()
        local player = game.Players.LocalPlayer
        local destPos = (dest == "Hydra") and CFrame.new(3000,0,-3000) or CFrame.new(2000,0,2000)
        while currentMission == "PULL" do
            updateLeviathanInfo()
            if leviathanInfo.heartDropped and leviathanInfo.heartPosition then
                Notify("❤️ Tìm thấy tim","Đang lái đến tim...",2)
                break
            end
            Notify("Chờ tim","Chưa thấy tim Leviathan",2)
            task.wait(2)
        end
        while currentMission == "PULL" and leviathanInfo.heartPosition do
            local dist = (leviathanInfo.heartPosition - player.Character.HumanoidRootPart.Position).Magnitude
            if dist < 30 then break end
            controlBoat(leviathanInfo.heartPosition, settings.slowSpeed)
            task.wait(1)
        end
        while currentMission == "PULL" do
            updateLeviathanInfo()
            if not leviathanInfo.heartPosition then
                Notify("Lỗi","Mất tim!",2); break
            end
            local distToDest = (destPos.Position - leviathanInfo.heartPosition).Magnitude
            if distToDest < 150 then
                Notify("🏁 Hoàn thành","Đã kéo tim về "..dest,3)
                currentMission = "NONE"
                break
            end
            controlBoat(destPos.Position, settings.slowSpeed)
            task.wait(1)
        end
        avoidanceActive = false
        stopAvoidance()
    end)
end

local function stopMission()
    if currentMission ~= "NONE" then
        currentMission = "NONE"
        avoidanceActive = false
        stopAvoidance()
        Notify("Dừng","Đã hủy nhiệm vụ",2)
    else
        Notify("Không có","Không có nhiệm vụ đang chạy",1)
    end
end
