local function Notify(title, text, duration)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title, Text = text, Duration = duration or 3
    })
end

local function checkChipStatus()
    local player = game.Players.LocalPlayer
    local bp = player:FindFirstChild("Backpack")
    local char = player.Character
    if bp then
        for _, it in pairs(bp:GetChildren()) do
            if it.Name and (it.Name:lower():find("chip") or it.Name:lower():find("leviathan")) then
                leviathanInfo.hasChip = true; return true
            end
        end
    end
    if char then
        for _, it in pairs(char:GetChildren()) do
            if it.Name and (it.Name:lower():find("chip") or it.Name:lower():find("leviathan")) then
                leviathanInfo.hasChip = true; return true
            end
        end
    end
    leviathanInfo.hasChip = false; return false
end

local function buyChip()
    if checkChipStatus() then Notify("Chip","✅ Đã có chip!",2) return end
    local player = game.Players.LocalPlayer
    local npc
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name and v.Name:lower():find("explorer") then npc = v; break end
    end
    if not npc then Notify("Lỗi","Không tìm thấy NPC Explorer!",3) return end
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local npcPos = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if npcPos then hrp.CFrame = npcPos.CFrame * CFrame.new(0,0,5); task.wait(1) end
    end
    for _, v in pairs(player.PlayerGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible and v.Text:lower():find("chip") then
            pcall(function() v:Click() end); break
        end
    end
    task.wait(1)
    if checkChipStatus() then Notify("Chip","🛒 Đã mua Chip thành công!",2)
    else Notify("Chip","❌ Mua thất bại, cần 1000$?",3) end
end

local function updateLeviathanInfo()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and obj.Name:lower():find("leviathan") then
            leviathanInfo.isActive = true
            leviathanInfo.lastSeen = tick()
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hrp then leviathanInfo.position = hrp.Position end
            local hum = obj:FindFirstChild("Humanoid")
            if hum then leviathanInfo.health = math.floor(hum.Health) end
            return
        end
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and (obj.Name:lower():find("heart") or obj.Name:lower():find("leviathanheart")) then
            leviathanInfo.heartDropped = true
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            leviathanInfo.heartPosition = hrp and hrp.Position or obj.Position
            return
        end
    end
    if tick() - (leviathanInfo.lastSeen or 0) > 60 then
        leviathanInfo.isActive = false; leviathanInfo.health = 0
    end
end
