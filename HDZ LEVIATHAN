local function mission_FindAndShoot()
    if currentMission ~= "NONE" then Notify("Đang bận","Dừng nhiệm vụ trước",2) return end
    currentMission = "FIND"
    avoidActive = true
    startAvoid()
    task.spawn(function()
        if not spawnBoat() then currentMission="NONE"; avoidActive=false; return end
        task.wait(1)
        if not getInBoat() then Notify("Lỗi","Không lên được thuyền",2); currentMission="NONE"; avoidActive=false; return end
        while currentMission == "FIND" do
            updateLevi()
            if leviInfo.active and leviInfo.pos then
                Notify("✅ Tìm thấy","Leviathan đã xuất hiện!",2)
                break
            end
            controlBoat(CFrame.new(5000,0,-2000).Position, settings.fastSpeed)
            task.wait(2)
        end
        while currentMission == "FIND" and leviInfo.pos do
            local dist = (leviInfo.pos - character.HumanoidRootPart.Position).Magnitude
            if dist < 60 then break end
            controlBoat(leviInfo.pos, settings.fastSpeed)
            task.wait(1)
        end
        local attempts = 0
        while currentMission == "FIND" and attempts < settings.maxShootAttempts do
            updateLevi()
            if not leviInfo.active then
                Notify("Leviathan chết","Chờ tim rơi...",2)
                task.wait(3)
                updateLevi()
                if leviInfo.heartPos then
                    Notify("❤️ Tim rơi","Chuyển sang kéo tim",2)
                    currentMission = "PULL"
                    break
                else
                    Notify("Chưa thấy tim","Thử lại...",2)
                end
                attempts = attempts + 1
                continue
            end
            shootAt(leviInfo.pos)
            attempts = attempts + 1
            Notify("Bắn tim","Lần "..attempts.."/"..settings.maxShootAttempts,1)
            local oldHealth = leviInfo.health
            task.wait(1)
            updateLevi()
            if leviInfo.health < oldHealth - 300 then
                Notify("❤️ Trúng tim!","Leviathan bị thương nặng",2)
                task.wait(3)
                updateLevi()
                if not leviInfo.active then
                    Notify("🎉 Tiêu diệt","Kết thúc nhiệm vụ",3)
                    currentMission = "NONE"
                    break
                end
            else
                adjustAim(leviInfo.pos)
                task.wait(0.5)
            end
        end
        if attempts >= settings.maxShootAttempts and currentMission=="FIND" then
            Notify("Thất bại","Không bắn trúng tim",3)
            currentMission = "NONE"
        end
        avoidActive = false; stopAvoid()
    end)
end
